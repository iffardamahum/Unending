<% content_for :title, "Edit: #{@bin.name} – Marco Polo" %>

<%# Breadcrumb %>
<div class="text-[12px] text-mp-faint mb-2.5 flex items-center gap-1.5">
  <%= link_to "HTTP Bins", http_bins_path, class: "text-mp-muted-text no-underline hover:underline" %>
  <span class="opacity-40">／</span>
  <%= link_to @bin.name, http_bin_path(@bin), class: "text-mp-muted-text no-underline hover:underline" %>
  <span class="opacity-40">／</span>
  <span class="text-mp-text">Edit</span>
</div>

<div class="flex items-center gap-3.5 mb-7">
  <div class="w-11 h-11 bg-mp-primary-dim border border-mp-primary-bdr rounded-xl flex items-center justify-center shrink-0">
    <svg class="w-5 h-5 text-mp-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z"/></svg>
  </div>
  <div>
    <h1 class="text-[1.5rem] font-bold m-0 tracking-tight">Edit Bin</h1>
    <p class="text-[12px] text-mp-muted-text mt-1 mb-0">Update endpoint settings and descriptions.</p>
  </div>
</div>

<div class="max-w-[540px]">
  <div class="bg-mp-card border border-mp-border rounded-2xl overflow-hidden shadow-[0_24px_64px_rgba(0,0,0,0.4)] transition-colors duration-200">
    <div class="p-6 pb-4">
      <%= form_with model: @bin do |f| %>

        <div class="mb-4">
          <%= f.label :name, class: "block text-[12px] font-medium text-mp-text mb-1.5" %>
          <%= f.text_field :name, class: "w-full bg-mp-elevated border border-mp-border-hi rounded-lg text-mp-text text-[13px] font-sans p-2 px-3 outline-none transition-all duration-150 focus:border-mp-primary focus:ring-4 focus:ring-mp-primary-dim placeholder:text-mp-faint", placeholder: "e.g. Payment Service Tests" %>
        </div>

        <div class="mb-4">
          <%= f.label :description, class: "block text-[12px] font-medium text-mp-text mb-1.5" %>
          <%= f.text_area :description, rows: 3, class: "w-full bg-mp-elevated border border-mp-border-hi rounded-lg text-mp-text text-[13px] font-sans p-2 px-3 outline-none transition-all duration-150 focus:border-mp-primary focus:ring-4 focus:ring-mp-primary-dim placeholder:text-mp-faint resize-y", placeholder: "What is this bin for?" %>
        </div>

        <div class="bg-mp-elevated border-t border-mp-border p-4 px-6 flex items-center gap-3 -mx-6 -mb-4 mt-6">
          <%= f.submit "Update Bin",
                class: "bg-mp-primary text-white border-none rounded-lg text-[13px] font-semibold py-2 px-[22px] cursor-pointer font-sans shadow-[0_4px_16px_rgba(139,92,246,0.3)] transition-all hover:opacity-90 active:scale-[0.98]" %>
          <%= link_to "Cancel", http_bin_path(@bin),
                class: "text-[13px] text-mp-faint no-underline hover:text-mp-text transition-colors" %>
        </div>

      <% end %>
    </div>
  </div>
</div>
