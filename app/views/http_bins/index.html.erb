<% content_for :title, "HTTP Bins – Marco Polo" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-slate-900">HTTP Bins</h1>
  <%= link_to "+ New Bin", new_http_bin_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700" %>
</div>

<% if @bins.any? %>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @bins.each do |bin| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 hover:border-indigo-300 transition">
        <div class="flex items-start justify-between">
          <div>
            <%= link_to bin.name, http_bin_path(bin), class: "font-semibold text-slate-900 hover:text-indigo-600" %>
            <p class="text-xs text-slate-400 mt-0.5 font-mono">/b/<%= bin.token %></p>
          </div>
          <span class="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">
            <%= bin.captured_requests.count %> reqs
          </span>
        </div>
        <% if bin.description.present? %>
          <p class="text-sm text-slate-500 mt-2"><%= bin.description.truncate(80) %></p>
        <% end %>
        <div class="flex gap-3 mt-4 text-xs">
          <%= link_to "View", http_bin_path(bin), class: "text-indigo-600 hover:underline" %>
          <%= link_to "Edit", edit_http_bin_path(bin), class: "text-slate-400 hover:text-slate-600" %>
          <%= button_to "Delete", http_bin_path(bin), method: :delete,
                data: { turbo_confirm: "Delete this bin and all its data?" },
                class: "text-red-400 hover:text-red-600" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-dashed border-slate-300 p-16 text-center">
    <div class="text-4xl mb-3">🗂️</div>
    <h3 class="text-lg font-semibold text-slate-700 mb-2">No bins yet</h3>
    <p class="text-slate-400 text-sm mb-6">Create a bin to start capturing HTTP requests.</p>
    <%= link_to "Create your first bin →", new_http_bin_path, class: "bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-indigo-700" %>
  </div>
<% end %>
