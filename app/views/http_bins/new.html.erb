<% content_for :title, "New HTTP Bin – Marco Polo" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">New HTTP Bin</h1>
  <p class="text-slate-500 mt-1">Create a unique URL to start capturing requests.</p>
</div>

<div class="max-w-lg">
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
    <%= form_with model: @bin, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500", placeholder: "e.g. Payment Service Tests" %>
      </div>
      <div>
        <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :description, rows: 3, class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500", placeholder: "What is this bin for?" %>
      </div>
      <div class="flex gap-3">
        <%= f.submit "Create Bin", class: "bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-indigo-700 cursor-pointer" %>
        <%= link_to "Cancel", http_bins_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
