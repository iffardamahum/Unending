<% content_for :title, "Dashboard – Marco Polo" %>

<%
  avg_ms = begin
    all = @bins.flat_map { |b| b.captured_requests.pluck(:duration_ms).compact }
    all.any? ? (all.sum / all.size.to_f).round : 0
  rescue
    0
  end

  if @stats[:yesterday] == 0
    trend       = "No data yesterday"
    trend_color = "text-mp-faint"
  else
    diff = @stats[:today] - @stats[:yesterday]
    pct  = ((diff.to_f / @stats[:yesterday]) * 100).round
    if diff > 0
      trend       = "↑ #{pct}% from yesterday"
      trend_color = "text-mp-green"
    elsif diff < 0
      trend       = "↓ #{pct.abs}% from yesterday"
      trend_color = "text-mp-red"
    else
      trend       = "Same as yesterday"
      trend_color = "text-mp-faint"
    end
  end

  stat_cards = [
    { label: "Total Endpoints",   value: @bins.count,
      sub: "+#{@bins.count { |b| b.created_at >= 7.days.ago }} this week",
      sub_color: "text-violet-300", border: "border-l-mp-primary" },
    { label: "Today's Requests",  value: @stats[:today],
      sub: trend, sub_color: trend_color, border: "border-l-mp-green" },
    { label: "Avg Response Time", value: "#{avg_ms}ms",
      sub: "Mock overhead", sub_color: "text-mp-faint", border: "border-l-purple-500" },
    { label: "Mock Rules",        value: @stats[:total_rules],
      sub: "Across all endpoints", sub_color: "text-mp-faint", border: "border-l-orange-500" },
  ]
%>

<%# ── Page header ── %>
<div class="flex items-start justify-between mb-10">
  <div>
    <h1 class="text-[1.75rem] font-bold tracking-tight m-0 flex items-center gap-2.5 text-mp-text">
      <span class="bg-mp-primary/15 border border-mp-primary/25 rounded-[10px] w-10 h-10 inline-flex items-center justify-center text-[20px] shrink-0">🧭</span>
      Mock Endpoints
    </h1>
    <p class="text-mp-muted-text text-[13px] mt-1.5 mb-0">Capture, inspect, and mock HTTP requests</p>
  </div>
  <%= link_to "+ Create Endpoint", new_http_bin_path, class: "bg-mp-primary text-white border-none rounded-[9px] py-2.5 px-[22px] text-[13px] font-semibold cursor-pointer font-sans no-underline shadow-[0_4px_18px_rgba(139,92,246,0.35)] tracking-tight transition-all duration-150 inline-block hover:opacity-90 hover:shadow-[0_4px_24px_rgba(139,92,246,0.5)]" %>
</div>

<%# ── Stat cards ── %>
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <% stat_cards.each do |card| %>
    <div class="bg-mp-card border border-mp-border rounded-xl p-5 border-l-4 <%= card[:border] %> relative overflow-hidden transition-all duration-200 hover:shadow-2xl hover:shadow-black/40">
      <div class="text-[10px] text-mp-faint uppercase tracking-widest font-semibold"><%= card[:label] %></div>
      <div class="text-[2rem] font-bold tracking-tight text-mp-text leading-none my-2"><%= card[:value] %></div>
      <div class="text-[11px] <%= card[:sub_color] %>"><%= card[:sub] %></div>
    </div>
  <% end %>
</div>

<%# ── Endpoints table ── %>
<div class="bg-mp-card border border-mp-border rounded-[14px] overflow-hidden mb-6">
  <div class="p-4 px-6 border-b border-mp-border flex items-center justify-between">
    <h2 class="text-[14px] font-semibold m-0 text-mp-text">Your Endpoints</h2>
    <span class="text-[11px] text-mp-faint"><%= @bins.count %> total</span>
  </div>
  <table class="w-full border-collapse text-[13px]">
    <thead>
      <tr class="bg-[#0c0c16]">
        <th class="py-2.5 px-5 text-left text-mp-faint text-[10px] font-semibold uppercase tracking-wider">Name</th>
        <th class="py-2.5 px-5 text-left text-mp-faint text-[10px] font-semibold uppercase tracking-wider">Token</th>
        <th class="py-2.5 px-5 text-left text-mp-faint text-[10px] font-semibold uppercase tracking-wider">Owner</th>
        <th class="py-2.5 px-5 text-left text-mp-faint text-[10px] font-semibold uppercase tracking-wider">Requests</th>
        <th class="py-2.5 px-5 text-left text-mp-faint text-[10px] font-semibold uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @bins.each do |bin| %>
        <% req_count = bin.captured_requests.count %>
        <tr class="border-t border-[#14141f] hover:bg-white/[0.015] transition-colors">
          <td class="py-3 px-5">
            <%= link_to http_bin_path(bin), class: "flex items-center gap-2 font-semibold text-violet-300 no-underline" do %>
              <span class="text-[16px]">🗂️</span>
              <%= bin.name %>
            <% end %>
          </td>
          <td class="py-3 px-5">
            <code class="text-[11px] bg-mp-elevated text-mp-muted-text py-0.5 px-2 rounded-[5px] font-mono">
              <%= bin.token.truncate(18, omission: "…") %>
            </code>
          </td>
          <td class="py-3 px-5 text-mp-faint text-[12px]"><%= bin.user.email %></td>
          <td class="py-3 px-5">
            <span class="inline-flex items-center justify-center min-w-10 px-2.5 py-0.5 rounded-full text-[11px] font-bold <%= req_count > 0 ? 'bg-violet-500/15 text-violet-300' : 'bg-mp-elevated text-mp-faint' %>">
              <%= req_count %>
            </span>
          </td>
          <td class="py-3 px-5">
            <div class="flex items-center gap-3.5">
              <%= link_to "View", http_bin_path(bin), class: "text-[12px] text-mp-primary font-medium no-underline hover:underline" %>
              <%= link_to "Edit", edit_http_bin_path(bin), class: "text-[12px] text-mp-muted-text font-medium no-underline hover:underline" %>
              <%= button_to "Delete", http_bin_path(bin), method: :delete,
                    data: { turbo_confirm: "Delete this bin?" },
                    class: "text-[12px] text-mp-red font-medium bg-transparent border-none p-0 cursor-pointer font-sans hover:underline" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @bins.empty? %>
        <tr class="border-t border-[#14141f]">
          <td colspan="5" class="text-center py-16 px-4 text-mp-faint text-[13px]">
            No endpoints yet.<br>
            <%= link_to "Create your first one →", new_http_bin_path,
                  class: "text-mp-primary no-underline hover:underline mt-2 inline-block font-semibold" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ── Endpoint Explorer ── %>
<% unless @bins.empty? %>

<style>
  .db-wrap {
    display: flex;
    height: 520px;
    background: var(--mp-card);
    border: 1px solid var(--mp-border);
    border-radius: 14px;
    overflow: hidden;
  }

  /* Sidebar */
  .db-sidebar { width:220px; flex-shrink:0; border-right:1px solid var(--mp-border); display:flex; flex-direction:column; }
  .db-sidebar-head { padding:10px 16px; border-bottom:1px solid var(--mp-border); background:#0a0a14; display:flex; align-items:center; justify-content:space-between; }
  .db-sidebar-head span { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--mp-faint); }
  .db-sidebar-body { overflow-y:auto; flex:1; }
  .db-bin-btn { width:100%; text-align:left; padding:10px 16px; border:none; border-bottom:1px solid #0d0d1a; background:none; cursor:pointer; display:block; transition:background .15s; border-left:2px solid transparent; box-sizing:border-box; }
  .db-bin-btn:hover { background:rgba(255,255,255,.025); }
  .db-bin-btn.active { background:rgba(124,58,237,.08); border-left-color:#7c3aed; padding-left:14px; }
  .db-bin-name { font-size:12px; font-weight:600; color:var(--mp-text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-bottom:3px; }
  .db-bin-meta { font-size:10px; color:var(--mp-faint); }
  .db-bin-meta .reqs { color:#a78bfa; }
  .db-active-dot { width:6px; height:6px; border-radius:50%; background:#4ade80; flex-shrink:0; }

  /* Right area */
  .db-right { flex:1; overflow:hidden; display:flex; flex-direction:column; min-width:0; }
  .db-panel { display:none; flex-direction:column; height:100%; }
  .db-panel.active { display:flex; }

  /* Panel header */
  .db-panel-head { padding:10px 20px; border-bottom:1px solid var(--mp-border); background:#0a0a14; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .db-panel-head-left { display:flex; align-items:center; gap:10px; min-width:0; }
  .db-panel-title { font-size:13px; font-weight:600; color:var(--mp-text); }
  .db-panel-token { font-size:10px; color:var(--mp-faint); font-family:Menlo,Consolas,monospace; display:block; margin-top:1px; }
  .db-panel-actions { display:flex; align-items:center; gap:12px; flex-shrink:0; margin-left:12px; }
  .db-panel-actions a { font-size:11px; font-weight:500; color:var(--mp-primary); text-decoration:none; }
  .db-panel-actions a:last-child { color:var(--mp-muted-text); }

  /* Mini stats */
  .db-mini-stats { display:grid; grid-template-columns:repeat(3,1fr); border-bottom:1px solid var(--mp-border); flex-shrink:0; }
  .db-mini-stat { padding:10px 20px; }
  .db-mini-stat + .db-mini-stat { border-left:1px solid var(--mp-border); }
  .db-mini-stat-label { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--mp-faint); margin-bottom:2px; }
  .db-mini-stat-value { font-size:1.25rem; font-weight:700; line-height:1.2; }

  /* Two-column body */
  .db-cols { display:flex; flex:1; overflow:hidden; min-height:0; }
  .db-col { overflow-y:auto; display:flex; flex-direction:column; min-width:0; }
  .db-col-rules { width:50%; flex-shrink:0; }
  .db-col-reqs  { flex:1; }

  /* Drag divider */
  .db-divider { width:5px; background:#0d0d1a; cursor:col-resize; flex-shrink:0; position:relative; transition:background .15s; z-index:2; }
  .db-divider:hover, .db-divider.dragging { background:var(--mp-primary); }
  .db-divider::after { content:''; position:absolute; top:0; bottom:0; left:-4px; right:-4px; }

  /* Column headers */
  .db-col-head { padding:7px 16px; border-bottom:1px solid #0d0d1a; background:#090913; position:sticky; top:0; z-index:1; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .db-col-head-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--mp-faint); display:flex; align-items:center; gap:5px; }
  .db-col-head a { font-size:10px; font-weight:600; color:var(--mp-primary); text-decoration:none; }
  .db-col-head a:hover { text-decoration:underline; }

  /* Filter bar */
  .db-filter-bar { padding:5px 16px; background:rgba(124,58,237,.08); border-bottom:1px solid rgba(124,58,237,.2); font-size:10px; color:#a78bfa; display:none; align-items:center; justify-content:space-between; flex-shrink:0; }
  .db-filter-bar.visible { display:flex; }
  .db-filter-clear { background:none; border:none; color:#a78bfa; font-size:10px; cursor:pointer; font-family:inherit; padding:0; text-decoration:underline; }
  .db-filter-clear:hover { color:#f87171; }

  /* Empty state */
  .db-empty { padding:28px 16px; text-align:center; font-size:12px; color:var(--mp-faint); }
  .db-empty a { color:var(--mp-primary); text-decoration:none; }

  /* Rule rows */
  .db-rule-row { padding:9px 16px; border-bottom:1px solid #0d0d1a; transition:background .12s; cursor:pointer; }
  .db-rule-row:hover { background:rgba(255,255,255,.025); }
  .db-rule-row.selected { background:rgba(124,58,237,.1); border-left:2px solid #7c3aed; padding-left:14px; }
  .db-rule-row.selected:hover { background:rgba(124,58,237,.14); }
  .db-rule-top { display:flex; align-items:center; gap:7px; margin-bottom:4px; }
  .db-rule-bottom { display:flex; align-items:center; justify-content:space-between; gap:8px; }
  .db-rule-name { font-size:11px; color:var(--mp-faint); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; }
  .db-rule-meta { display:flex; align-items:center; gap:8px; flex-shrink:0; }

  /* Request rows */
  .db-req-row { padding:7px 16px; border-bottom:1px solid #0d0d1a; display:flex; align-items:center; gap:8px; transition:background .12s; }
  .db-req-row:hover { background:rgba(255,255,255,.018); }
  .db-req-row.hidden { display:none; }
  .db-req-path { font-size:11px; color:var(--mp-text); font-family:Menlo,Consolas,monospace; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; }
  .db-req-dur  { font-size:10px; color:var(--mp-faint); font-family:Menlo,Consolas,monospace; width:42px; text-align:right; flex-shrink:0; }

  /* Badges */
  .db-badge        { font-size:9px; font-weight:700; font-family:Menlo,Consolas,monospace; padding:2px 5px; border-radius:4px; flex-shrink:0; }
  .db-badge-GET    { background:rgba(59,130,246,.15);  color:#93c5fd; }
  .db-badge-POST   { background:rgba(34,197,94,.15);   color:#86efac; }
  .db-badge-PUT    { background:rgba(234,179,8,.15);   color:#fde047; }
  .db-badge-PATCH  { background:rgba(249,115,22,.15);  color:#fdba74; }
  .db-badge-DELETE { background:rgba(239,68,68,.15);   color:#fca5a5; }
  .db-badge-OTHER  { background:rgba(255,255,255,.06); color:var(--mp-faint); }

  /* Status colors */
  .db-sc-2 { color:#4ade80; }
  .db-sc-3 { color:#93c5fd; }
  .db-sc-4 { color:#fbbf24; }
  .db-sc-5 { color:#f87171; }

  /* Status pills */
  .db-pill-on  { font-size:9px; background:rgba(74,222,128,.12);  color:#4ade80; padding:2px 7px; border-radius:4px; font-weight:700; flex-shrink:0; border:1px solid rgba(74,222,128,.2); }
  .db-pill-off { font-size:9px; background:rgba(248,113,113,.12); color:#f87171; padding:2px 7px; border-radius:4px; font-weight:700; flex-shrink:0; border:1px solid rgba(248,113,113,.2); }

  /* Links */
  .db-edit-link { font-size:10px; color:var(--mp-faint); text-decoration:none; flex-shrink:0; transition:color .12s; }
  .db-edit-link:hover { color:var(--mp-primary); }
  .db-view-link { font-size:10px; color:var(--mp-primary); text-decoration:none; flex-shrink:0; font-weight:500; }
  .db-view-link:hover { text-decoration:underline; }
</style>

<div class="db-wrap">

  <%# ── Sidebar ── %>
  <div class="db-sidebar">
    <div class="db-sidebar-head">
      <span>Endpoints</span>
      <span style="font-size:10px;color:var(--mp-faint);"><%= @bins.count %> total</span>
    </div>
    <div class="db-sidebar-body">
      <% @bins.each_with_index do |bin, idx| %>
        <%
          bin_rule_count = bin.mock_rules.count
          bin_req_count  = bin.captured_requests.count
          is_active      = bin.captured_requests.where('created_at >= ?', 1.hour.ago).exists?
        %>
        <button type="button"
                data-bin-id="<%= bin.id %>"
                onclick="dbSelectBin(<%= bin.id %>)"
                class="db-bin-btn <%= idx == 0 ? 'active' : '' %>">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">
            <div class="db-bin-name"><%= bin.name %></div>
            <% if is_active %>
              <div class="db-active-dot" title="Active in last hour"></div>
            <% end %>
          </div>
          <div class="db-bin-meta">
            <%= bin_rule_count %> rule<%= bin_rule_count == 1 ? '' : 's' %>&ensp;·&ensp;<span class="<%= bin_req_count > 0 ? 'reqs' : '' %>"><%= bin_req_count %> req<%= bin_req_count == 1 ? '' : 's' %></span>
          </div>
        </button>
      <% end %>
    </div>
  </div>

  <%# ── Right panels ── %>
  <div class="db-right">
    <% @bins.each_with_index do |bin, idx| %>
      <%
        rules    = bin.mock_rules.order(priority: :desc, created_at: :desc)
        requests = bin.captured_requests.order(created_at: :desc).limit(50)
        bin_avg  = begin
          d = bin.captured_requests.pluck(:duration_ms).compact
          d.any? ? (d.sum / d.size.to_f).round : 0
        rescue; 0; end
      %>
      <div id="db-panel-<%= bin.id %>" class="db-panel <%= idx == 0 ? 'active' : '' %>">

        <%# Panel header %>
        <div class="db-panel-head">
          <div class="db-panel-head-left">
            <span style="font-size:15px;">🗂️</span>
            <div style="min-width:0;">
              <div class="db-panel-title"><%= bin.name %></div>
              <code class="db-panel-token"><%= bin.token %></code>
            </div>
          </div>
          <div class="db-panel-actions">
            <%= link_to "View", http_bin_path(bin) %>
            <%= link_to "Edit", edit_http_bin_path(bin) %>
          </div>
        </div>

        <%# Mini stats %>
        <div class="db-mini-stats">
          <div class="db-mini-stat">
            <div class="db-mini-stat-label">Mock Rules</div>
            <div class="db-mini-stat-value" style="color:#a78bfa;"><%= rules.count %></div>
          </div>
          <div class="db-mini-stat">
            <div class="db-mini-stat-label">Captured Reqs</div>
            <div class="db-mini-stat-value" style="color:#93c5fd;"><%= bin.captured_requests.count %></div>
          </div>
          <div class="db-mini-stat">
            <div class="db-mini-stat-label">Avg Response</div>
            <div class="db-mini-stat-value" style="color:var(--mp-text);"><%= bin_avg %>ms</div>
          </div>
        </div>

        <%# Two columns with drag divider %>
        <div class="db-cols" id="db-cols-<%= bin.id %>">

          <%# Mock Rules column %>
          <div class="db-col db-col-rules" id="db-rules-<%= bin.id %>">
            <div class="db-col-head">
              <span class="db-col-head-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.992l1.003.827c.447.365.67.95.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                Mock Rules
              </span>
              <%= link_to "+ Add", new_http_bin_mock_rule_path(bin) %>
            </div>

            <% if rules.empty? %>
              <div class="db-empty">
                No rules yet.<br>
                <%= link_to "Add a rule →", new_http_bin_mock_rule_path(bin) %>
              </div>
            <% else %>
              <% rules.each do |rule| %>
                <%
                  mc = case rule.http_method
                    when "GET"    then "db-badge-GET"
                    when "POST"   then "db-badge-POST"
                    when "PUT"    then "db-badge-PUT"
                    when "PATCH"  then "db-badge-PATCH"
                    when "DELETE" then "db-badge-DELETE"
                    else "db-badge-OTHER"
                  end
                  sc = rule.response_status.to_i
                  sc_class = sc >= 500 ? "db-sc-5" : sc >= 400 ? "db-sc-4" : sc >= 300 ? "db-sc-3" : "db-sc-2"
                %>
                <div class="db-rule-row"
                     data-rule-id="<%= rule.id %>"
                     data-bin-id="<%= bin.id %>"
                     onclick="dbFilterByRule(<%= bin.id %>, <%= rule.id %>, '<%= j(rule.name) %>: <%= j(rule.path_pattern) %>')">
                  <div class="db-rule-top">
                    <span class="db-badge <%= mc %>"><%= rule.http_method %></span>
                    <code style="font-size:11px;color:var(--mp-text);font-family:Menlo,Consolas,monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;"><%= rule.path_pattern %></code>
                    <% if rule.enabled %>
                      <span class="db-pill-on">Active</span>
                    <% else %>
                      <span class="db-pill-off">Inactive</span>
                    <% end %>
                  </div>
                  <div class="db-rule-bottom">
                    <span class="db-rule-name"><%= rule.name %></span>
                    <div class="db-rule-meta">
                      <span class="<%= sc_class %>" style="font-size:10px;font-family:Menlo,Consolas,monospace;font-weight:700;"><%= rule.response_status %></span>
                      <%= link_to "Edit", edit_http_bin_mock_rule_path(bin, rule), class: "db-edit-link", onclick: "event.stopPropagation();" %>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# Drag divider %>
          <div class="db-divider"
               data-cols="db-cols-<%= bin.id %>"
               data-left="db-rules-<%= bin.id %>"></div>

          <%# Captured Requests column %>
          <div class="db-col db-col-reqs">
            <div class="db-col-head">
              <span class="db-col-head-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
                Captured Requests
              </span>
              <%= link_to "View all →", http_bin_path(bin) %>
            </div>

            <%# Filter bar — shown when a rule is selected %>
            <div class="db-filter-bar" id="db-filter-bar-<%= bin.id %>">
              <span id="db-filter-label-<%= bin.id %>">Filtered by rule</span>
              <button class="db-filter-clear" onclick="dbClearFilter(<%= bin.id %>)">✕ Show all</button>
            </div>

            <% if requests.empty? %>
              <div class="db-empty">
                No requests captured yet.<br>
                Send one to <code style="font-family:Menlo,Consolas,monospace;color:#a78bfa;">/b/<%= bin.token.truncate(20) %></code>
              </div>
            <% else %>
              <% requests.each do |req| %>
                <%
                  mc2 = case req.http_method
                    when "GET"    then "db-badge-GET"
                    when "POST"   then "db-badge-POST"
                    when "PUT"    then "db-badge-PUT"
                    when "PATCH"  then "db-badge-PATCH"
                    when "DELETE" then "db-badge-DELETE"
                    else "db-badge-OTHER"
                  end
                  sc2 = req.response_status.to_i rescue 0
                  sc2_class = sc2 >= 500 ? "db-sc-5" : sc2 >= 400 ? "db-sc-4" : sc2 >= 300 ? "db-sc-3" : "db-sc-2"
                %>
                <div class="db-req-row" data-matched-rule="<%= req.mock_rule_id %>">
                  <span class="db-badge <%= mc2 %>"><%= req.http_method %></span>
                  <span class="db-req-path"><%= req.path %></span>
                  <span class="<%= sc2_class %>" style="font-size:11px;font-family:Menlo,Consolas,monospace;font-weight:700;flex-shrink:0;"><%= req.response_status %></span>
                  <span class="db-req-dur"><%= req.duration_ms ? "#{req.duration_ms}ms" : "—" %></span>
                  <%= link_to "View", http_bin_captured_request_path(bin, req), class: "db-view-link" %>
                </div>
              <% end %>
            <% end %>
          </div>

        </div><%# end db-cols %>
      </div><%# end db-panel %>
    <% end %>
  </div><%# end db-right %>

</div><%# end db-wrap %>

<script>
  /* ── Bin switcher ── */
  function dbSelectBin(id) {
    document.querySelectorAll(".db-panel").forEach(p => p.classList.remove("active"));
    document.querySelectorAll(".db-bin-btn").forEach(b => b.classList.remove("active"));
    const panel = document.getElementById("db-panel-" + id);
    if (panel) panel.classList.add("active");
    const btn = document.querySelector(`.db-bin-btn[data-bin-id="${id}"]`);
    if (btn) btn.classList.add("active");
  }

  /* ── Rule filter ── */
  function dbFilterByRule(binId, ruleId, label) {
    const panel       = document.getElementById("db-panel-" + binId);
    const filterBar   = document.getElementById("db-filter-bar-" + binId);
    const filterLabel = document.getElementById("db-filter-label-" + binId);

    // Toggle off if same rule clicked again
    const alreadySelected = panel.querySelector(`.db-rule-row[data-rule-id="${ruleId}"].selected`);
    if (alreadySelected) { dbClearFilter(binId); return; }

    // Highlight selected rule
    panel.querySelectorAll(".db-rule-row").forEach(r => r.classList.remove("selected"));
    const clicked = panel.querySelector(`.db-rule-row[data-rule-id="${ruleId}"]`);
    if (clicked) clicked.classList.add("selected");

    // Filter request rows
    let count = 0;
    panel.querySelectorAll(".db-req-row").forEach(r => {
      const match = String(r.dataset.matchedRule) === String(ruleId);
      r.classList.toggle("hidden", !match);
      if (match) count++;
    });

    // Show filter bar
    if (filterBar) {
      filterBar.classList.add("visible");
      filterLabel.textContent = `${count} request${count === 1 ? '' : 's'} matched "${label}"`;
    }
  }

  function dbClearFilter(binId) {
    const panel     = document.getElementById("db-panel-" + binId);
    const filterBar = document.getElementById("db-filter-bar-" + binId);
    panel.querySelectorAll(".db-rule-row").forEach(r => r.classList.remove("selected"));
    panel.querySelectorAll(".db-req-row").forEach(r => r.classList.remove("hidden"));
    if (filterBar) filterBar.classList.remove("visible");
  }

  /* ── Resizable divider ── */
  document.querySelectorAll(".db-divider").forEach(divider => {
    divider.addEventListener("mousedown", e => {
      const colsEl  = document.getElementById(divider.dataset.cols);
      const leftCol = document.getElementById(divider.dataset.left);
      if (!colsEl || !leftCol) return;

      const startX     = e.clientX;
      const startWidth = leftCol.offsetWidth;

      divider.classList.add("dragging");
      document.body.style.cursor     = "col-resize";
      document.body.style.userSelect = "none";

      const onMove = e => {
        const delta    = e.clientX - startX;
        const maxWidth = colsEl.offsetWidth - 160;
        const newWidth = Math.min(Math.max(startWidth + delta, 120), maxWidth);
        leftCol.style.width = newWidth + "px";
        leftCol.style.flex  = "none";
      };

      const onUp = () => {
        divider.classList.remove("dragging");
        document.body.style.cursor     = "";
        document.body.style.userSelect = "";
        document.removeEventListener("mousemove", onMove);
        document.removeEventListener("mouseup",   onUp);
      };

      document.addEventListener("mousemove", onMove);
      document.addEventListener("mouseup",   onUp);
      e.preventDefault();
    });
  });
</script>

<% end %>
