<% content_for :title, "Reset password – Marco Polo" %>

<%# Top bar %>
<div class="fixed top-0 left-0 right-0 h-[52px] flex items-center justify-between px-5 bg-mp-bg border-b border-mp-border z-50 transition-colors duration-200">
  <a href="/" class="flex items-center gap-2 text-[14px] font-semibold text-mp-text no-underline tracking-tight">
    <%= image_tag "valbury.png", alt: "Marco Polo", class: "w-8 h-8 object-contain shrink-0" %>
    Marco Polo
  </a>
  <button id="auth-theme-btn" class="w-8 h-8 bg-mp-elevated border border-mp-border-hi rounded-lg cursor-pointer flex items-center justify-center text-[15px] transition-colors duration-200 shrink-0 p-0 leading-none hover:bg-mp-muted text-mp-text" onclick="authToggleTheme()" title="Toggle theme"></button>
</div>

<%# Centered reset password form %>
<div class="min-h-screen flex items-center justify-center pt-[72px] p-4 pb-8">
  <div class="w-full max-w-[360px] text-center">

    <div class="w-14 h-14 mx-auto mb-5 bg-gradient-to-br from-violet-500 to-violet-700 rounded-2xl flex items-center justify-center shadow-[0_8px_24px_rgba(109,40,217,0.4)]">
      <%= image_tag "valbury.png", alt: "Marco Polo", class: "w-8 h-8 object-contain" %>
    </div>

    <h1 class="text-[1.5rem] font-bold tracking-tight m-0 mb-1">Forgot password?</h1>
    <p class="text-[13px] text-mp-muted-text m-0 mb-6">We'll send you reset instructions</p>

    <%= form_for resource, as: resource_name, url: password_path(resource_name), html: { method: :post } do |f| %>
      <% if resource.errors.any? %>
        <div class="mb-3 p-2.5 px-3.5 bg-red-500/10 border border-red-500/25 rounded-xl text-[12px] text-red-400 text-left">
          <% resource.errors.full_messages.each do |msg| %><p class="my-0.5"><%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="bg-mp-card border border-mp-border rounded-2xl overflow-hidden mb-4 transition-colors duration-200">
        <div class="p-3 px-4 border-b border-mp-border last:border-b-0">
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email",
                class: "w-full bg-transparent border-none outline-none text-[13px] text-mp-text placeholder:text-mp-faint" %>
        </div>
        <button type="submit" class="w-full p-3 px-4 bg-mp-primary text-white border-none text-[13px] font-semibold cursor-pointer font-sans transition-opacity hover:opacity-90 tracking-tight">Send reset instructions</button>
      </div>
    <% end %>

    <p class="text-[13px] text-mp-muted-text">
      Remember it?
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-mp-primary font-semibold no-underline hover:underline" %>
    </p>

    <p class="text-[11px] text-mp-faint mt-6">Internal platform · Marcopolo v1.0</p>
  </div>
</div>

<script>
  (function() {
    var moonSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>`;
    var sunSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9.75-9h-2.25m-13.5 0H3m16.035-7.035-1.591 1.591M21 21l-1.591-1.591m-14.7-.291-1.591 1.591M3 3l1.591 1.591M12 7.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"/></svg>`;

    var t = localStorage.getItem("mp-theme") || "dark";
    document.documentElement.dataset.theme = t;
    var btn = document.getElementById("auth-theme-btn");
    if (btn) btn.innerHTML = t === "dark" ? moonSvg : sunSvg;
  })();
  function authToggleTheme() {
    var moonSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>`;
    var sunSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9.75-9h-2.25m-13.5 0H3m16.035-7.035-1.591 1.591M21 21l-1.591-1.591m-14.7-.291-1.591 1.591M3 3l1.591 1.591M12 7.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"/></svg>`;

    var next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("mp-theme", next);
    document.getElementById("auth-theme-btn").innerHTML = next === "dark" ? moonSvg : sunSvg;
  }
</script>