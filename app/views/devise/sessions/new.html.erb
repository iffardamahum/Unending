<% content_for :title, "Sign in – Marco Polo" %>

<%# Top bar %>
<div class="fixed top-0 left-0 right-0 h-[52px] flex items-center justify-between px-5 bg-mp-bg border-b border-mp-border z-50 transition-colors duration-200">
  <a href="/" class="flex items-center gap-2 text-[14px] font-semibold text-mp-text no-underline tracking-tight">
      <span class="text-xl font-bold">Unending</span>
  </a>
  <button id="auth-theme-btn" class="w-8 h-8 bg-mp-elevated border border-mp-border-hi rounded-lg cursor-pointer flex items-center justify-center text-[15px] transition-colors duration-200 shrink-0 p-0 leading-none hover:bg-mp-muted text-mp-text" onclick="authToggleTheme()" title="Toggle theme"></button>
</div>

<%# Centered sign-in form %>
<div class="min-h-screen flex items-center justify-center pt-[72px] p-4 pb-8">
  <div class="w-full max-w-[360px] text-center">

      <div class="w-14 h-14 mx-auto mb-5 bg-linear-to-br from-violet-500 to-violet-700 rounded-2xl flex items-center justify-center shadow-[0_8px_24px_rgba(109,40,217,0.4)]">
        <span class="text-xl font-bold">Unending</span>
      </div>

    <h1 class="text-[1.5rem] font-bold tracking-tight m-0 mb-1">Sign in</h1>
    <p class="text-[13px] text-mp-muted-text m-0 mb-6">to Marco Polo</p>

    <div class="bg-mp-card border border-mp-border rounded-2xl overflow-hidden mb-4 transition-colors duration-200">
      <%= link_to user_google_oauth2_omniauth_authorize_path, class: "flex items-center gap-3 p-3 px-4 text-[13px] text-mp-text no-underline transition-colors hover:bg-mp-elevated" do %>
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      <% end %>
    </div>

    <div class="flex items-center gap-3 mb-4 text-mp-faint text-[11px] before:content-[''] before:flex-1 before:h-px before:bg-mp-border after:content-[''] after:flex-1 after:h-px after:bg-mp-border">or</div>

    <%= form_for resource, as: resource_name, url: session_path(resource_name) do |f| %>
      <div class="bg-mp-card border border-mp-border rounded-2xl overflow-hidden mb-4 transition-colors duration-200">
        <div class="p-3 px-4 border-b border-mp-border">
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email",
                class: "w-full bg-transparent border-none outline-none text-[13px] text-mp-text placeholder:text-mp-faint" %>
        </div>
        <div class="p-3 px-4 border-b border-mp-border last:border-b-0">
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Password",
                class: "w-full bg-transparent border-none outline-none text-[13px] text-mp-text placeholder:text-mp-faint" %>
        </div>
        <button type="submit" class="w-full p-3 px-4 bg-mp-primary text-white border-none text-[13px] font-semibold cursor-pointer font-sans transition-opacity hover:opacity-90 tracking-tight">Sign in</button>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center justify-between px-0.5 mb-3 text-[12px] text-mp-faint">
          <label class="flex items-center gap-1.5 cursor-pointer">
            <%= f.check_box :remember_me, class: "w-3.5 h-3.5 accent-mp-primary cursor-pointer" %>
            Remember me
          </label>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-mp-primary no-underline hover:underline" %>
        </div>
      <% end %>
    <% end %>

    <p class="text-[13px] text-mp-muted-text">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-mp-primary font-semibold no-underline hover:underline" %>
    </p>

    <p class="text-[11px] text-mp-faint mt-6">Internal platform · Marcopolo v1.0</p>
  </div>
</div>

<script nonce="<%= request.content_security_policy_nonce %>">
  (function() {
    var moonSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>`;
    var sunSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9.75-9h-2.25m-13.5 0H3m16.035-7.035-1.591 1.591M21 21l-1.591-1.591m-14.7-.291-1.591 1.591M3 3l1.591 1.591M12 7.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"/></svg>`;

    var t = localStorage.getItem("mp-theme") || "dark";
    document.documentElement.dataset.theme = t;
    var btn = document.getElementById("auth-theme-btn");
    if (btn) btn.innerHTML = t === "dark" ? moonSvg : sunSvg;
  })();

  function authToggleTheme() {
    var moonSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>`;
    var sunSvg = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m9.75-9h-2.25m-13.5 0H3m16.035-7.035-1.591 1.591M21 21l-1.591-1.591m-14.7-.291-1.591 1.591M3 3l1.591 1.591M12 7.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z"/></svg>`;

    var next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    localStorage.setItem("mp-theme", next);
    document.getElementById("auth-theme-btn").innerHTML = next === "dark" ? moonSvg : sunSvg;
  }
</script>
