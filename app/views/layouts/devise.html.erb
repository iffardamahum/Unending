<!DOCTYPE html>
<html data-theme="dark">
  <head>
    <title><%= content_for(:title) || "Marco Polo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      (function() {
        var t = localStorage.getItem("mp-theme") || "dark";
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>

  <body class="bg-mp-bg text-mp-text min-h-screen transition-colors duration-200">
    <% if notice.present? %>
      <div class="fixed top-[52px] left-0 right-0 z-50 p-4">
        <div class="bg-mp-green-dim border border-mp-green-bdr text-mp-green rounded-[10px] py-2.5 px-4 text-[13px] flex items-center gap-2 max-w-[400px] mx-auto shadow-lg shadow-black/40">✅ <%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed top-[52px] left-0 right-0 z-50 p-4">
        <div class="bg-mp-red-dim border border-mp-red-bdr text-mp-red rounded-[10px] py-2.5 px-4 text-[13px] flex items-center gap-2 max-w-[400px] mx-auto shadow-lg shadow-black/40">⚠️ <%= alert %></div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>