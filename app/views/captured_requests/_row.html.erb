<%
  method_classes = {
    "GET"    => "bg-blue-500/15 text-blue-400",
    "POST"   => "bg-emerald-500/15 text-emerald-400",
    "PUT"    => "bg-amber-500/15 text-amber-400",
    "PATCH"  => "bg-violet-500/15 text-violet-400",
    "DELETE" => "bg-red-500/15 text-red-400",
  }
  method_cls = method_classes[captured_request.http_method] || "bg-violet-500/15 text-violet-400"
  status_ok  = captured_request.response_status < 400
%>
<tr id="captured_request_<%= captured_request.id %>" class="border-t border-[#14141f] hover:bg-mp-primary-dim transition-colors duration-150">
  <td class="py-2.5 px-3.5 align-middle">
    <span class="inline-block font-mono text-[10px] font-bold py-0.5 px-2 rounded <%= method_cls %>"><%= captured_request.http_method %></span>
  </td>
  <td class="py-2.5 px-3.5 align-middle font-mono text-[11px] text-mp-muted-text max-w-[200px] overflow-hidden text-overflow-ellipsis whitespace-nowrap">
    <%= captured_request.path %>
  </td>
  <td class="py-2.5 px-3.5 align-middle">
    <span class="font-mono text-[12px] font-bold <%= status_ok ? 'text-mp-green' : 'text-mp-red' %>">
      <%= captured_request.response_status %>
    </span>
  </td>
  <td class="py-2.5 px-3.5 align-middle text-center">
    <% if captured_request.matched_mock %>
      <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-mp-primary-hi bg-mp-primary-dim px-2 py-0.5 rounded-full">
        Mock
      </span>
    <% else %>
      <span class="text-mp-faint">—</span>
    <% end %>
  </td>
  <td class="py-2.5 px-3.5 align-middle font-mono text-[11px] text-mp-faint">
    <%= "#{captured_request.duration_ms}ms" if captured_request.duration_ms %>
  </td>
  <td class="py-2.5 px-3.5 align-middle text-[11px] text-mp-faint">
    <%= time_ago_in_words(captured_request.created_at) %> ago
  </td>
  <td class="py-2.5 px-3.5 align-middle">
    <%= link_to "View",
          http_bin_captured_request_path(captured_request.http_bin_id, captured_request),
          class: "text-[12px] text-mp-primary font-medium no-underline hover:underline" %>
  </td>
</tr>
